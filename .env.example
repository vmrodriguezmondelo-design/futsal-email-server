# Email Server Configuration
# Copy this file to .env and fill in your actual values

# Email Server Port
EMAIL_SERVER_PORT=3007

# SMTP Configuration (Email sending)
SMTP_HOST=smtp.serviciodecorreo.es
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=delegado@adsala10.es
SMTP_PASS=your_email_password_here
SMTP_FROM=delegado@adsala10.es

# Firebase Configuration (optional - for Firebase Admin SDK)
# If not using Admin SDK, push notifications will use REST API fallback
GOOGLE_APPLICATION_CREDENTIALS=./ropa-wanapix-firebase-key.json

# Firebase Push Notification Configuration
FIREBASE_PROJECT_ID=ropa-wanapix
FIREBASE_API_KEY=AIzaSyB4IzSgdhzgra7PzbqXR4EkN5eXxm51sl4

# Optional: Custom settings
NODE_ENV=production
LOG_LEVEL=info
